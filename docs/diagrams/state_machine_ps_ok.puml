@startuml

title Power Switch States

skinparam defaultTextAlignment center

state "MB OFF\nPSU OFF" as mb_off_psu_off
state "MB START\nPSU ON" as mb_start_psu_on
state "MB ON\nPSU ON" as mb_on_psu_on
state "MB STOP\nPSU ON" as mb_stop_psu_on
state "MB OFF\nPSU ON" as mb_off_psu_on

' Power on
[*] --> mb_off_psu_off
mb_off_psu_off --> mb_off_psu_on : PWR_SW Pressed\nâ†’PS_ON Low\nâ†’BOOT:=1
mb_off_psu_on --> mb_start_psu_on : BOOT=1 & PS_OK High\nâ†’MOS Low
mb_start_psu_on --> mb_on_psu_on : MB_ON High\nâ†’WAIT\nâ†’SLEEP

' Soft power off
mb_on_psu_on --> mb_stop_psu_on : PWR_SW Pressed\nâ†’MB_ACPI High
mb_on_psu_on --> mb_stop_psu_on : OS_OFF\nâ†’WAIT
mb_stop_psu_on --> mb_off_psu_on : MB_ON Low\nâ†’MOS High\nâ†’BOOT:=0
mb_off_psu_on --> mb_off_psu_off : BOOT=0\nâ†’PS_ON High\nâ†’SLEEP

' Hard power off
mb_on_psu_on --> mb_off_psu_off : PWR_SW Held\nâ†’PS_ON High

@enduml