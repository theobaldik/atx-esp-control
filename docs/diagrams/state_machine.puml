hide empty description

skinparam defaultTextAlignment center

state "MB OFF\nPSU OFF" as mb_off_psu_off
state "MB START\nPSU ON" as mb_start_psu_on
state "MB ON\nPSU ON" as mb_on_psu_on
state "MB STOP\nPSU ON" as mb_stop_psu_on
state "MB OFF\nPSU ON" as mb_off_psu_on

' Power on
[*] --> mb_off_psu_off
mb_off_psu_off --> mb_off_psu_on : PWR_SW Pressed\nâ†’WAKEUP\nâ†’BOOT:=1\nâ†’PS_ON Low
mb_off_psu_on --> mb_start_psu_on : BOOT=1\nâ†’WAIT
mb_start_psu_on --> mb_on_psu_on : MB_ON High\nâ†’SLEEP

' Soft power off
mb_on_psu_on --> mb_stop_psu_on : PWR_SW Pressed\nâ†’WAKEUP\nâ†’BOOT:=0\nâ†’MB_ACPI High
